# Git ignore for Green Agentic RAG System

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Do not ignore frontend/lib (Next.js shared client code)
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Secrets / env files (never commit real keys)
.env
.env.*
!.env.example
!.env.*.example
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Backend specific
backend/temp_uploads/
backend/agentic_db.sqlite
backend/local_db/
agentic_db.sqlite

# Frontend specific
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.DS_Store

# Local virtualenvs
.venv/
.venv-frontend/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test files
*.test.js
coverage/
