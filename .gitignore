# Git ignore for Green Agentic RAG System

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Do not ignore frontend/lib (Next.js shared client code)
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Secrets / env files (never commit real keys)
.env
.env.*
!.env.example
!.env.*.example
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Backend specific
backend/temp_uploads/
backend/agentic_db.sqlite
backend/agentic_db_e2e.sqlite
backend/local_db/
agentic_db.sqlite
*.sqlite

# Generated eval / diagnostics / traces (keep only REPO_* cleanup reports)
backend/eval_out/**
!backend/eval_out/REPO_INVENTORY.md
!backend/eval_out/REPO_CLEANUP_REPORT.md

# Coverage / test caches
.coverage
*.coverage
htmlcov/
.pytest_cache/
backend/.pytest_cache/
coverage/
.mypy_cache/
.ruff_cache/

# Vector / retrieval local caches (regenerable)
**/chroma/
**/.cache/
backend/**/bm25*.pkl
backend/**/*.faiss

# Frontend specific
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.DS_Store
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Local virtualenvs
.venv/
.venv-frontend/
venv/
backend/.venv/

# Graphify / architecture graph exports (regenerate locally)
graphify-out/
graphify-out-docs-smoke/

# Generated / ephemeral evaluation fixtures
eval_docs/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs / profiling
*.log
logs/
*.prof
*.flamegraph

# Local Vercel / deploy link state
.vercel/
frontend/.vercel/

# Test files
*.test.js

# Temporary scratch
tmp/
temp/
scratch/
debug/
draft/
**/tmp/
**/temp/
**/scratch/
