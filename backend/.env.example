# === Runtime environment ===
# development | testing | production
APP_ENV=development
APP_NAME=Green Agentic API
APP_VERSION=4.1.0

# === NVIDIA NIM API ===
# Get a free key at https://build.nvidia.com/settings/api-keys
# Endpoint 1 (primary) — backward compatible
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# === Offline GPT benchmarking (developer-only; NOT used by production RAG) ===
# Used only by: python run_benchmark.py  (or /dev/benchmark/gpt when enabled)
OPENAI_API_KEY=
# Mount POST /dev/benchmark/gpt only when true (default off; never wired to UI)
ENABLE_GPT_BENCHMARK=false
# Required header X-Benchmark-Token when the endpoint is mounted
BENCHMARK_ADMIN_TOKEN=

# === Gemini (graphify knowledge graph — docs/papers/images) ===
# Graphify reads process env only; from repo root run:
#   .\scripts\run-graphify.ps1
# Or:  $env:GEMINI_API_KEY="..." ; graphify .
GEMINI_API_KEY=
GEMINI_API_KEY=
GRAPHIFY_GEMINI_MODEL=gemini-flash-lite-latest
# Do not set GRAPHIFY_DISABLE_THINKING for Gemini (Google rejects that payload).
# From repo root:  .\scripts\run-graphify.ps1
# Tip: if gemini-2.5-flash hits free-tier daily quota, use gemini-flash-lite-latest.

# Multi-endpoint pool (least-load). Paste keys from 2–3 NIM accounts.
NIM_ENDPOINT_POOL_ENABLED=true
NIM_ENDPOINT_STRATEGY=least_load
NIM_ENDPOINT_MAX_CONCURRENT=6
NIM_ENDPOINT_ACQUIRE_TIMEOUT_SEC=120
NIM_SOFT_TTFT_TIMEOUT_SEC=45
NIM_HARD_TIMEOUT_SEC=75
MAP_CHUNK_HARD_TIMEOUT_SEC=90
CAPACITY_SCHEDULER_ENABLED=true
MAP_EMPTY_RETRY_ATTEMPTS=2
NIM_ENDPOINT_RETRIES_PER_MODEL=2
NIM_ENDPOINT_1_ROLES=map,compile,embed,any
NIM_ENDPOINT_2_API_KEY=
NIM_ENDPOINT_2_BASE_URL=
NIM_ENDPOINT_2_ROLES=map,compile,embed,any
NIM_ENDPOINT_3_API_KEY=
NIM_ENDPOINT_3_BASE_URL=
NIM_ENDPOINT_3_ROLES=map,compile,embed,any
# Optional: NIM_API_KEYS=key2,key3  (same BASE_URL as primary)

# Per-request timeout for NIM chat/embeddings (seconds). Prevents hung jobs.
NIM_HTTP_TIMEOUT_SEC=75
NIM_TRANSIENT_RETRIES=1
# Global NIM throttle (token bucket shared by all workers). Safe free-tier default.
NIM_RATE_LIMITER_ENABLED=true
NIM_MAX_REQUESTS_PER_MINUTE=30
NIM_RATE_LIMIT_MAX_REQUEUES=8
# Per-model time slices inside the shared MAP/COMPILE wall (prevents primary starvation).
CHAIN_SLICE_ENABLED=true
MAP_CHAIN_SLICE_FRACTIONS=0.45,0.35,0.20
COMPILE_CHAIN_SLICE_FRACTIONS=0.40,0.35,0.25
CHAIN_SLICE_MIN_SEC=8
# If primary exceeds its compile slice, fire fallback concurrently (extra NIM spend).
COMPILE_HEDGED_FALLBACK_ENABLED=true
MODEL_RELIABILITY_WINDOW=50
MODEL_RELIABILITY_SOFT_DEPRIORITIZE=false
MODEL_RELIABILITY_TIMEOUT_RATE_THRESHOLD=0.55
MODEL_RELIABILITY_MIN_SAMPLES=20
# Must be strictly less than COMPILE_CALL_MAX_SEC (default 180).
NIM_COMPILE_TIMEOUT_SEC=55
NIM_CONNECT_TIMEOUT_SEC=15
# OpenAI SDK transport retries (app also retries transient errors / falls across models)
NIM_SDK_MAX_RETRIES=1
NIM_TRANSIENT_RETRIES=2
# Large-PDF compile resilience + DAG hierarchy
COMPILE_MAX_INPUT_TOKENS=10000
COMPILE_BATCH_SIZE=8
# Reserved wall for executive compile (map/regional/chapter cannot consume this).
COMPILE_RESERVED_SEC=60
DAG_COMPILE_ENABLED=true
COMPILE_CONTEXT_WINDOW_TOKENS=12000
COMPILE_PROMPT_MAX_CONTEXT_FRAC=0.80
# With 3 endpoints: 16 map / 12 compile is a good starting point
MAP_MAX_WORKERS=12
EMBEDDED_MAP_MAX_WORKERS=12
COMPILE_MAX_WORKERS=6
VALIDATE_MAX_WORKERS=8
PROGRESS_WRITE_INTERVAL_SEC=0.75
ENABLE_EMBED_PREFETCH=true
ELECTRICITY_MAPS_CACHE_TTL_SEC=300

# Optional: Electricity Maps (live grid intensity for CO₂e = energy × intensity)
ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key_here
# Leave ZONE empty to resolve via lat/lon (default Pune → IN-WE)
ELECTRICITY_MAPS_ZONE=
ELECTRICITY_MAPS_LAT=18.52
ELECTRICITY_MAPS_LON=73.85

# === Carbon-Aware Region Scheduler (single live region today) ===
# Modes: single-region (enabled) | carbon-optimized (future multi-region)
REGION_SCHEDULER_MODE=single-region
REGION_SCHEDULER_DEFAULT_REGION=india
REGION_SCHEDULER_DEFAULT_REGION_NAME=India
REGION_SCHEDULER_PROVIDER=electricity_maps

# === Light tier (chunk summarization) ===
LIGHT_MODEL_PRIMARY=meta/llama-3.2-3b-instruct
LIGHT_MODEL_FALLBACK=google/gemma-2-2b-it

# === Medium tier ===
MEDIUM_MODEL_PRIMARY=mistralai/ministral-14b-instruct-2512
MEDIUM_MODEL_FALLBACK=google/gemma-4-31b-it

# === Heavy tier (final compile + RAG answers) ===
HEAVY_MODEL_PRIMARY=meta/llama-3.3-70b-instruct
HEAVY_MODEL_FALLBACK_1=openai/gpt-oss-120b
HEAVY_MODEL_FALLBACK_2=qwen/qwen3.5-122b-a10b

# === Retrieval (embeddings + rerank) ===
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
RAG_CANDIDATE_K=20
RAG_TOP_K=5

# === Phase 2.B Hybrid Retrieval + Embedding Cache ===
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_EMBEDDING_CACHE=true
RAG_DENSE_K=20
RAG_SPARSE_K=20
RAG_RRF_K=20
RAG_RERANK_N=20
ENABLE_PARENT_EXPAND=true
RAG_PARENT_EXPAND_MAX=3

# === Phase 2.C ContextAssembler ===
USE_CONTEXT_ASSEMBLER=true
CONTEXT_DEDUP_THRESHOLD=0.92
CONTEXT_TOKEN_BUDGET_LIGHT=2000
CONTEXT_TOKEN_BUDGET_MEDIUM=4000
CONTEXT_TOKEN_BUDGET_HEAVY=6000

# === Phase 2.D Response Agent ===
USE_RESPONSE_AGENT=true
RESPONSE_DEFAULT_SKILL=qa
RESPONSE_USE_ROUTING_DECISION=true

# === Phase 2.F Understanding Agent ===
ENABLE_UNDERSTANDING=true
UNDERSTANDING_MAX_CHUNKS_PER_CALL=6
UNDERSTANDING_MAX_TOKENS=2000

# === Phase 2.G GraphStore + graph-seeded retrieval ===
ENABLE_GRAPH_SEED=true
GRAPH_SEED_MAX_CHUNKS=8
GRAPH_SEED_MIN_CONFIDENCE=0.4

# === Phase 2.H Memory + Explainability ===
EXPLAINABILITY_ENABLED=true
CONVERSATION_TTL_HOURS=24
CONVERSATION_MAX_TURNS=40

# === Capability Requirement Engine (CRE) ===
CRE_POLICY_VERSION=cre-v1.0
CRE_WEIGHT_REASONING=0.35
CRE_WEIGHT_STRUCTURAL=0.20
CRE_WEIGHT_COHERENCE=0.20
CRE_WEIGHT_RETRIEVAL=0.25
CRE_HEAVY_COMPILE_CHUNK_THRESHOLD=20

# === Quality Validation Agent ===
QVA_CONFIDENCE_THRESHOLD=0.60
QVA_FAITHFULNESS_MIN=0.55
QVA_HALLUCINATION_MAX=0.15
QVA_CONTRADICTION_MAX=0.10
QVA_MAX_ESCALATIONS=1

# === Telemetry ===
ROUTING_TELEMETRY_PATH=./local_db/routing_telemetry.jsonl

# === Database ===
# Local (default): SQLite
DATABASE_URL=sqlite:///./agentic_db.sqlite
# Production example (Postgres):
# DATABASE_URL=postgresql://user:pass@host:5432/green_agentic
# Local Docker Postgres:
# DATABASE_URL=postgresql://green:green@localhost:5432/green_agentic

VECTOR_DB_PATH=./local_db/aux
CHROMA_PERSIST_DIRECTORY=./local_db/chroma
CHROMA_COLLECTION_NAME=documents_nemotron_v2
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# Prefer Alembic (scripts/migrate_*.sh). True only for emergency local bootstrap.
AUTO_CREATE_SCHEMA=false
RUN_MIGRATIONS_ON_STARTUP=false

# Durable runtime state (set false to roll back to legacy stores)
PERSIST_JOBS_TO_DB=true
PERSIST_CONVERSATIONS_TO_DB=true
PERSIST_ROUTING_EVENTS_TO_DB=true
ROUTING_TELEMETRY_JSONL_FALLBACK=true

# === Durable worker (Phase 3) — run: python -m src.worker ===
# No Celery/Redis/Kafka — jobs table is the queue
WORKER_ID=
WORKER_POLL_INTERVAL_SEC=2
WORKER_CLAIM_TIMEOUT_SEC=180
WORKER_HEARTBEAT_INTERVAL_SEC=10
WORKER_HEARTBEAT_STALE_SEC=60
COMPILE_CALL_MAX_SEC=600
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BACKOFF_SEC=30
WORKER_RECLAIM_INTERVAL_SEC=30
WORKER_SHUTDOWN_GRACE_SEC=120
# Large PDFs with NIM fallbacks need longer than 10 minutes
JOB_MAX_RUNTIME_SEC=1800
# Free-tier: run worker inside the API web service (no paid Background Worker)
# Set true on Render Web Service env; leave false if you use a separate worker.
RUN_EMBEDDED_WORKER=false
FEATURE_EXTRACTION_OPTIONAL=true


# === Chroma vector store (embedded PersistentClient) ===
# Embeddings live under CHROMA_PERSIST_DIRECTORY (not a remote Chroma server).
# VECTOR_DB_PATH is for BM25 / embed cache / file conversations only.

# === Carbon Settings (optimization constraint, not primary router) ===
BASELINE_GRID_INTENSITY=450.0
LOCAL_GRID_INTENSITY=700.0

# Optional: WattTime (carbon-router helpers). Never commit real values.
WATTTIME_USERNAME=
WATTTIME_PASSWORD=
WATTTIME_EMAIL=
WATTTIME_ORG=

# === Uploads ===
# Authenticated user cap (guests remain at 25 MiB via GUEST_MAX_PDF_BYTES).
MAX_UPLOAD_BYTES=52428800

# === Document Processing ===
TRIAGE_STRATEGY=fast

# === Phase 2.A Adaptive Chunking ===
USE_ADAPTIVE_CHUNKING=true
# Production structure parser (heading validation → semantic sections → pack)
USE_STRUCTURE_PARSER=true
HEADING_CONFIDENCE_THRESHOLD=0.55
STRUCTURE_TARGET_TOKENS=800
STRUCTURE_MIN_TOKENS=450
STRUCTURE_MAX_TOKENS=1200
STRUCTURE_MERGE_SIM_MIN=0.28
CHUNK_MAX_TOKENS=1500
CHUNK_SIM_THRESHOLD=0.15
CHUNK_MIN_TOKENS_BEFORE_SIM_SPLIT=500
CHUNK_MAX_COUNT=4096
CHUNK_FORCE_CAP=false
CHUNK_TITLE_AS_CHUNK=false
# Leave empty to use CHROMA_COLLECTION_NAME
CHUNK_COLLECTION_NAME=

# === Authentication ===
# REQUIRED in production (≥32 chars). NEVER put this (or any server secret) in NEXT_PUBLIC_* / frontend.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
# Short-lived access tokens; refresh renews the session
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
BCRYPT_ROUNDS=12
# Auth abuse protection (per-IP sliding windows)
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_WINDOW_SEC=900
AUTH_REGISTER_RATE_LIMIT=5
AUTH_REGISTER_RATE_WINDOW_SEC=3600
AUTH_REFRESH_RATE_LIMIT=60
AUTH_REFRESH_RATE_WINDOW_SEC=900
AUTH_GUEST_RATE_LIMIT=30
AUTH_GUEST_RATE_WINDOW_SEC=3600
# Abuse protection — API / AI generation / scrape + bot heuristics
ABUSE_PROTECTION_ENABLED=true
API_RATE_LIMIT=120
API_RATE_WINDOW_SEC=60
AI_RATE_LIMIT=20
AI_RATE_WINDOW_SEC=60
AI_RATE_LIMIT_GUEST=10
SCRAPE_RATE_LIMIT=60
SCRAPE_RATE_WINDOW_SEC=60
ABUSE_BLOCK_EMPTY_USER_AGENT=true
ABUSE_BLOCK_BOT_USER_AGENTS=true
ABUSE_BOT_LIMIT_FACTOR=0.25
# Optional httpOnly refresh cookie (path=/auth). Secure forced on in production.
AUTH_COOKIE_ENABLED=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# Cross-origin SPAs need refresh in JSON; set false for cookie-only sessions.
AUTH_RETURN_REFRESH_IN_BODY=true
# Transport security (production defaults FORCE_HTTPS=true via APP_ENV)
FORCE_HTTPS=
TRUST_PROXY_HEADERS=true
HSTS_MAX_AGE_SEC=31536000
# Optional: comma-separated hosts for TrustedHostMiddleware
TRUSTED_HOSTS=
# Reject public DATABASE_URL without TLS in production
DATABASE_REQUIRE_SSL=true

# === Object storage (Phase 2) — PDFs/files; embeddings stay in Chroma ===
# local | r2 | s3
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_LOCAL_ROOT=./local_db/object_store
# Cloudflare R2 (when OBJECT_STORAGE_BACKEND=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional override; default https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
R2_REGION=auto
# Optional public/CDN base for file_url metadata
R2_PUBLIC_BASE_URL=
# AWS S3 fallback (when OBJECT_STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
S3_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=

# === CORS ===
# Comma-separated allowlist (used when CORS_ALLOW_ALL=false or APP_ENV=production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# development/testing only — ignored in production
CORS_ALLOW_ALL=true
MAX_PARALLEL_WORKERS=12
