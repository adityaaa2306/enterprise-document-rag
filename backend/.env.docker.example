# Secrets / keys for local docker compose.
# Copy:  copy .env.docker.example .env.docker   (Windows)
#        cp .env.docker.example .env.docker     (macOS/Linux)
# Then set NVIDIA_API_KEY. Do NOT commit .env.docker.

APP_ENV=production
JWT_SECRET_KEY=change-me-docker-compose-dev-secret-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
ELECTRICITY_MAPS_API_KEY=

# Object storage — local volume in compose; use r2 for Render/prod
OBJECT_STORAGE_BACKEND=local

# Optional R2 (when OBJECT_STORAGE_BACKEND=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Must be strictly less than MAP_CHUNK_HARD_TIMEOUT_SEC (default 90)
NIM_HTTP_TIMEOUT_SEC=75
NIM_HARD_TIMEOUT_SEC=75
MAP_CHUNK_HARD_TIMEOUT_SEC=90
NIM_CONNECT_TIMEOUT_SEC=10
NIM_SDK_MAX_RETRIES=0
FEATURE_EXTRACTION_OPTIONAL=true
