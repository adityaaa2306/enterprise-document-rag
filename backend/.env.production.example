# Production environment checklist — Render + Vercel + Neon + R2
# Copy into dashboards — do not commit real secrets.
#
# Default production topology (embedded Chroma):
#   ONE Render Web Service with RUN_EMBEDDED_WORKER=true
#   so API (RAG reads) and worker (embedding writes) share /data/chroma.
#
# Do NOT run a separate Background Worker against PersistentClient unless
# both services share the same Chroma store (HttpClient / remote Chroma).

# === Vercel (frontend) — Root Directory: frontend ===
# NEXT_PUBLIC_API_URL=https://YOUR-API.onrender.com

# === Render Web Service (API + embedded worker) ===
APP_ENV=production
SERVICE_ROLE=api
PORT=8000
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require
JWT_SECRET_KEY=REPLACE_WITH_LONG_RANDOM
CORS_ALLOW_ALL=false
CORS_ORIGINS=https://YOUR-APP.vercel.app
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OBJECT_STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
CHROMA_PERSIST_DIRECTORY=/data/chroma
CHROMA_COLLECTION_NAME=documents_nemotron_v2
VECTOR_DB_PATH=/data/aux
RUN_MIGRATIONS_ON_STARTUP=true
AUTO_CREATE_SCHEMA=false
RUN_EMBEDDED_WORKER=true
WORKER_ID=embedded-api-1
PERSIST_JOBS_TO_DB=true
PERSIST_CONVERSATIONS_TO_DB=true
PERSIST_ROUTING_EVENTS_TO_DB=true
FEATURE_EXTRACTION_OPTIONAL=true
NIM_HTTP_TIMEOUT_SEC=90
NIM_CONNECT_TIMEOUT_SEC=10
NIM_SDK_MAX_RETRIES=0
JOB_MAX_RUNTIME_SEC=1800
MEDIUM_MODEL_PRIMARY=mistralai/ministral-14b-instruct-2512
MEDIUM_MODEL_FALLBACK=google/gemma-4-31b-it

# === Optional: separate Render Background Worker (NOT for embedded Chroma) ===
# Only after shared remote Chroma (HttpClient). Otherwise RAG breaks.
# RUN_EMBEDDED_WORKER=false on the API when using a separate worker.
# SERVICE_ROLE=worker
# RUN_MIGRATIONS_ON_STARTUP=false
# WORKER_ID=render-worker-1
# WORKER_SHUTDOWN_GRACE_SEC=120
# JWT_SECRET_KEY=MUST_MATCH_API_VALUE
# DATABASE_URL=same as API
# NVIDIA_API_KEY=same as API
# R2_*=same as API
