# Production environment checklist — Render + Vercel + Neon + R2
# Copy into dashboards — do not commit real secrets.
#
# The application currently uses an embedded Chroma instance for cost-efficient
# portfolio deployment. The production deployment architecture supports migrating
# to a standalone Chroma server (HttpClient) with no application-level changes
# beyond restoring the HttpClient factory branch.

# === Vercel (frontend) ===
# NEXT_PUBLIC_API_URL=https://green-agentic-api.onrender.com

# === Render Web Service (API) ===
APP_ENV=production
PORT=8000
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require
JWT_SECRET_KEY=REPLACE_WITH_LONG_RANDOM
CORS_ALLOW_ALL=false
CORS_ORIGINS=https://YOUR-APP.vercel.app
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OBJECT_STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
CHROMA_PERSIST_DIRECTORY=/data/chroma
CHROMA_COLLECTION_NAME=documents_nemotron_v2
VECTOR_DB_PATH=/data/aux
RUN_MIGRATIONS_ON_STARTUP=true
AUTO_CREATE_SCHEMA=false
PERSIST_JOBS_TO_DB=true
PERSIST_CONVERSATIONS_TO_DB=true
PERSIST_ROUTING_EVENTS_TO_DB=true

# === Render Background Worker (same Neon/R2/NIM; share chroma volume if used) ===
# RUN_MIGRATIONS_ON_STARTUP=false
# WORKER_ID=render-worker-1
# WORKER_SHUTDOWN_GRACE_SEC=120
# SERVICE_ROLE=worker
# JWT_SECRET_KEY=MUST_MATCH_API_VALUE
# CHROMA_PERSIST_DIRECTORY=/data/chroma
# DATABASE_URL=same as API
# NVIDIA_API_KEY=same as API
# R2_*=same as API
# CORS_ORIGINS=optional on worker (startup skips CORS validation)
